          <div class="scoring-item"><div class="scoring-round">Elite 8</div><div class="scoring-points">16</div></div>
          <div class="scoring-item"><div class="scoring-round">Final Four</div><div class="scoring-points">32</div></div>
          <div class="scoring-item"><div class="scoring-round">Championship</div><div class="scoring-points">32</div></div>
        </div>
      </div>
      <div class="scoring-section">
        <div class="scoring-title">Seed Multipliers</div>
        <div class="multiplier-grid">
          <div class="multiplier-item"><div class="multiplier-seeds">Seeds 1-4</div><div class="multiplier-value">1x</div></div>
          <div class="multiplier-item"><div class="multiplier-seeds">Seeds 5-8</div><div class="multiplier-value">1.5x</div></div>
          <div class="multiplier-item"><div class="multiplier-seeds">Seeds 9-12</div><div class="multiplier-value">2x</div></div>
          <div class="multiplier-item"><div class="multiplier-seeds">Seeds 13-16</div><div class="multiplier-value">3x</div></div>
        </div>
      </div>
    </div>
    <div class="panel" id="draft">
      <div class="draft-controls" id="draftControls">
        <button class="draft-btn primary" onclick="startDraft(false)">🚀 Start Draft</button>
        <button class="draft-btn test" onclick="startDraft(true)">🧪 Test Draft</button>
        <button class="draft-btn danger" onclick="resetDraft()" style="display:none" id="resetBtn">🔄 Reset</button>
        <button class="draft-btn secondary" onclick="endDraft()" style="display:none" id="endBtn">⏹️ End Draft</button>
      </div>
      <div class="draft-status inactive" id="draftStatus">
        <div>Click "Start Draft" or "Test Draft" to begin</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.5);margin-top:8px">Test mode lets you practice without saving picks</div>
      </div>
      <div class="draft-order" id="draftOrderSection">
        <div class="draft-order-title">Draft Order (Snake: 1→2→3→4→4→3→2→1...)</div>
        <div class="draft-order-list" id="draftOrderList"></div>
      </div>
      <div class="draft-teams-grid" id="draftTeamsGrid" style="display:none"></div>
      <div class="draft-board" id="draftBoard"></div>
    </div>
  </main>
  
  <div class="last-update" id="lastUpdate"></div>
  <button class="refresh-btn" onclick="loadData()">↻</button>
  
  <div class="popup-overlay" id="popupOverlay"><div class="team-popup" id="teamPopup"></div></div>
  <div class="toast" id="toast"></div>

  <script>
    let appData = null, teamsData = null, oddsData = null, liveScores = {};
    let draftTimer = null, draftTimeLeft = 120;
    
    document.querySelectorAll('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(tab.dataset.tab).classList.add('active');
      });
    });
    
    async function loadData() {
      try {
        const [dataRes, teamsRes, oddsRes, standingsRes] = await Promise.all([
          fetch('/api/data'), fetch('/api/teams'), fetch('/api/odds/all'), fetch('/api/standings')
        ]);
        appData = await dataRes.json();
        teamsData = await teamsRes.json();
        oddsData = await oddsRes.json();
        const standings = await standingsRes.json();
        
        renderRace(standings);
        renderStandings(standings);
        renderBracket();
        renderDraft();
        renderDraftOrder();
        renderDraftStatus();
        loadLiveGames();
        
        document.getElementById('lastUpdate').textContent = 'Last updated: ' + new Date(appData.lastUpdate).toLocaleString();
      } catch (err) { console.error('Failed to load:', err); }
    }
    
    function renderRace(standings) {
      const maxPossible = Math.max(...standings.map(s => s.maxPoints), 1);
      const leader = standings[0];
      document.getElementById('raceLanes').innerHTML = standings.map(s => {
        const progressPct = (s.totalPoints / maxPossible) * 100;
        const potentialPct = (s.potentialPoints / maxPossible) * 100;
        return `<div class="race-lane">
          <div class="race-avatar" style="background:linear-gradient(135deg,${s.colorPrimary},${s.colorSecondary})">${s.letter}</div>
          <div class="race-track">
            <div class="race-progress" style="width:${Math.max(progressPct,8)}%;background:linear-gradient(90deg,${s.colorPrimary},${s.colorSecondary})">${s.totalPoints}</div>
            <div class="race-potential" style="left:${progressPct}%;width:${potentialPct}%"></div>
          </div>
          <div class="race-info">${s.teamsAlive} alive</div>
        </div>`;
      }).join('');
      const gap = leader.totalPoints - (standings[1]?.totalPoints || 0);
      const maxP = standings.reduce((a,b) => a.maxPoints > b.maxPoints ? a : b);
      document.getElementById('racePills').innerHTML = `
        <div class="race-pill"><strong>${leader.name}</strong> leads by ${gap} pts</div>
        <div class="race-pill">Max potential: <strong>${maxP.name}</strong> (${maxP.maxPoints})</div>
        <div class="race-pill">${standings.reduce((sum,s) => sum + s.teamsAlive, 0)} teams alive</div>`;
    }
    
    function renderStandings(standings) {
      document.getElementById('standingsList').innerHTML = standings.map((s, i) => {
        const rank = i === 0 ? '👑' : i === 1 ? '🥈' : i === 2 ? '🥉' : `#${i+1}`;
        const chips = s.teams.map(t => {
          const team = teamsData[t]; if (!team) return '';
          let elim = false;
          for (const r of Object.keys(appData.bracket)) { const x = appData.bracket[r].find(y => y.name === t); if (x?.eliminated) elim = true; }
          return `<span class="team-chip ${elim?'eliminated':''}" style="background:linear-gradient(135deg,${team.colors[0]},${team.colors[0]}dd)" onclick="showTeamPopup('${t}')">${t}</span>`;
        }).join('');
        return `<div class="standing-card">
          <div class="standing-rank">${rank}</div>
          <div class="standing-avatar" style="background:linear-gradient(135deg,${s.colorPrimary},${s.colorSecondary})">${s.letter}</div>
          <div class="standing-info"><div class="standing-name">${s.name}</div><div class="standing-teams">${chips}</div></div>
          <div class="standing-points"><div class="points-current">${s.totalPoints}</div><div class="points-potential">+${s.potentialPoints} potential</div></div>
        </div>`;
      }).join('');
    }
    
    function getMatchups(regionTeams) {
      const sorted = [...regionTeams].sort((a,b) => a.seed - b.seed);
      const order = [1,16,8,9,5,12,4,13,6,11,3,14,7,10,2,15];
      const matchups = [];
      for (let i = 0; i < order.length; i += 2) {
        const t1 = sorted.find(t => t.seed === order[i]);
        const t2 = sorted.find(t => t.seed === order[i+1]);
        matchups.push([t1, t2]);
      }
      return matchups;
    }
    
    function renderBracket() {
      const regions = {left: ['East', 'South'], right: ['West', 'Midwest']};
      const roundNames = ['R64', 'R32', 'S16', 'E8'];
      let html = '';
      
      regions.left.forEach(region => {
        const teams = appData.bracket[region] || [];
        const matchups = getMatchups(teams);
        html += `<div class="bracket-region"><div class="region-label ${region.toLowerCase()}">${region.toUpperCase()}</div><div class="bracket-rounds">`;
        html += `<div class="bracket-round"><div class="round-label">Round 1</div>`;
        matchups.forEach(([t1, t2]) => { html += renderMatchup(t1, t2); });
        html += `</div>`;
        [4, 2, 1].forEach((count, ri) => {
          html += `<div class="bracket-round"><div class="round-label">${roundNames[ri+1]}</div>`;
          for (let i = 0; i < count; i++) { html += `<div class="matchup-empty">TBD</div>`; }
          html += `</div>`;
        });
        html += `</div></div>`;
      });
      
      html += `<div class="final-four">
        <div class="ff-label">FINAL FOUR</div>
        <div class="ff-matchup"><div class="ff-region">East Champion</div><div class="ff-team">TBD</div></div>
        <div class="ff-matchup"><div class="ff-region">South Champion</div><div class="ff-team">TBD</div></div>
        <div class="championship"><div class="trophy">🏆</div><div class="champ-label">CHAMPION</div><div class="champ-team">TBD</div></div>
        <div class="ff-matchup"><div class="ff-region">West Champion</div><div class="ff-team">TBD</div></div>
        <div class="ff-matchup"><div class="ff-region">Midwest Champion</div><div class="ff-team">TBD</div></div>
      </div>`;
      
      regions.right.forEach(region => {
        const teams = appData.bracket[region] || [];
        const matchups = getMatchups(teams);
        html += `<div class="bracket-region"><div class="region-label ${region.toLowerCase()}">${region.toUpperCase()}</div><div class="bracket-rounds" style="flex-direction:row-reverse">`;
        [1, 2, 4].forEach((count, ri) => {
          html += `<div class="bracket-round"><div class="round-label">${roundNames[3-ri]}</div>`;
          for (let i = 0; i < count; i++) { html += `<div class="matchup-empty">TBD</div>`; }
          html += `</div>`;
        });
        html += `<div class="bracket-round"><div class="round-label">Round 1</div>`;
        matchups.forEach(([t1, t2]) => { html += renderMatchup(t1, t2); });
        html += `</div></div></div>`;
      });
      
      document.getElementById('bracketContainer').innerHTML = html;
    }
    
    function renderMatchup(t1, t2) {
      if (!t1 || !t2) return '<div class="matchup-empty">TBD</div>';
      const live = liveScores[t1.name] || liveScores[t2.name];
      return `<div class="matchup ${live ? 'live' : ''}">${renderMatchupTeam(t1, live)}${renderMatchupTeam(t2, live)}${live ? `<div class="live-badge"><span class="live-dot"></span>${live.clock || 'LIVE'}</div>` : ''}</div>`;
    }
    
    function renderMatchupTeam(t, live) {
      const info = teamsData[t.name] || {};
      const seedClass = info.seed <= 4 ? 'seed-1-4' : info.seed <= 8 ? 'seed-5-8' : info.seed <= 12 ? 'seed-9-12' : 'seed-13-16';
      let owner = null;
      appData.players.forEach(p => { if (p.teams.includes(t.name)) owner = p; });
      const score = live?.scores?.[t.name];
      return `<div class="matchup-team ${t.eliminated ? 'eliminated' : ''} ${t.wins > 0 && !t.eliminated ? 'winner' : ''}" onclick="showTeamPopup('${t.name}')">
        <span class="seed-badge ${seedClass}">${info.seed || '?'}</span>
        <span class="team-name">${t.name}</span>
        ${owner ? `<span class="team-owner" style="background:linear-gradient(135deg,${owner.colorPrimary},${owner.colorSecondary})">${owner.letter}</span>` : ''}
        ${score !== undefined ? `<span class="team-score">${score}</span>` : ''}
      </div>`;
    }
    
    async function loadLiveGames() {
      try {
        const res = await fetch('/api/scores');
        const data = await res.json();
        liveScores = {};
        
        if (!data.events || data.events.length === 0) {
          document.getElementById('liveGames').innerHTML = `<div class="no-games"><div class="no-games-icon">🏀</div><div>No games right now</div><div style="margin-top:8px;font-size:13px">Check back during tournament games!</div></div>`;
          return;
        }
        
        const html = data.events.map(event => {
          const comp = event.competitions[0];
          const teams = comp.competitors;
          const status = comp.status;
          const isLive = status.type.state === 'in';
          const isFinal = status.type.completed;
          const broadcast = comp.broadcasts?.[0]?.names?.[0] || 'TV';
          
          if (isLive) {
            teams.forEach(t => {
              liveScores[t.team.displayName] = { clock: status.displayClock, scores: {} };
              teams.forEach(x => { liveScores[t.team.displayName].scores[x.team.displayName] = x.score; });
            });
          }
          
          const teamRows = teams.map(t => {
            const isWinner = isFinal && t.winner;
            let owner = null;
            appData.players.forEach(p => { if (p.teams.includes(t.team.displayName)) owner = p; });
            return `<div class="game-team ${isWinner ? 'winner' : ''}">
              <span class="seed-badge ${(t.curatedRank?.current||99) <= 4 ? 'seed-1-4' : 'seed-5-8'}">${t.curatedRank?.current || '-'}</span>
              <span class="team-name" style="flex:1">${t.team.displayName}</span>
              ${owner ? `<span class="team-owner" style="background:linear-gradient(135deg,${owner.colorPrimary},${owner.colorSecondary})">${owner.letter}</span>` : ''}
              <span class="game-score">${t.score || '-'}</span>
            </div>`;
          }).join('');
          
          return `<div class="live-game ${isLive ? 'is-live' : ''}">${teamRows}
            <div class="game-status">
              ${isLive ? `<div class="status-live"><span class="live-dot"></span>${status.displayClock || ''} - ${status.period === 1 ? '1st Half' : '2nd Half'}</div>` : isFinal ? `<span style="color:var(--green);font-size:12px;font-weight:600">✓ FINAL</span>` : `<span style="font-size:12px;color:rgba(255,255,255,0.5)">${new Date(event.date).toLocaleTimeString([],{hour:'numeric',minute:'2-digit'})}</span>`}
              <div style="display:flex;gap:8px;align-items:center">
                <span class="channel-badge">${broadcast}</span>
                <a href="https://www.ncaa.com/march-madness-live/watch" target="_blank" class="watch-btn">▶ Watch</a>
              </div>
            </div>
          </div>`;
        }).join('');
        
        document.getElementById('liveGames').innerHTML = html;
        renderBracket();
      } catch (err) {
        document.getElementById('liveGames').innerHTML = `<div class="no-games"><div class="no-games-icon">📡</div><div>Unable to load live scores</div></div>`;
      }
    }
    
    // DRAFT FUNCTIONS
    function renderDraftOrder() {
      const order = appData.draftState.order.length > 0 ? appData.draftState.order : [0, 1, 2, 3];
      document.getElementById('draftOrderList').innerHTML = order.map((playerIdx, i) => {
        const player = appData.players[playerIdx];
        const isActive = appData.draftState.active && getCurrentPickerIndex() === playerIdx;
        return `<div class="draft-order-item ${isActive ? 'active' : ''}">
          <span class="order-number">${i + 1}</span>
          <div class="order-avatar" style="background:linear-gradient(135deg,${player.colorPrimary},${player.colorSecondary})">${player.letter}</div>
          <span>${player.name}</span>
        </div>`;
      }).join('');
    }
    
    function getCurrentPickerIndex() {
      const state = appData.draftState;
      if (!state.active) return -1;
      const pickNum = state.currentPick;
      const round = Math.floor(pickNum / 4);
      const pos = pickNum % 4;
      const isReverse = round % 2 === 1;
      const orderIdx = isReverse ? (3 - pos) : pos;
      return state.order[orderIdx];
    }
    
    function renderDraftStatus() {
      const state = appData.draftState;
      const statusEl = document.getElementById('draftStatus');
      const teamsGrid = document.getElementById('draftTeamsGrid');
      const resetBtn = document.getElementById('resetBtn');
      const endBtn = document.getElementById('endBtn');
      
      if (state.active) {
        const pickerIdx = getCurrentPickerIndex();
        const picker = appData.players[pickerIdx];
        statusEl.className = state.testMode ? 'draft-status test-mode' : 'draft-status';
        statusEl.innerHTML = `
          ${state.testMode ? '<div style="color:#f59e0b;font-size:12px;font-weight:600;margin-bottom:8px">🧪 TEST MODE - Picks won\'t be saved</div>' : ''}
          <div class="draft-pick-number">Pick #${state.currentPick + 1} of 64</div>
          <div class="draft-current-player">
            <span style="display:inline-block;width:28px;height:28px;border-radius:6px;background:linear-gradient(135deg,${picker.colorPrimary},${picker.colorSecondary});vertical-align:middle;margin-right:8px;text-align:center;line-height:28px;font-size:14px;font-weight:700">${picker.letter}</span>
            ${picker.name}'s turn
          </div>
          <div class="draft-timer" id="draftTimerDisplay">2:00</div>
        `;
        teamsGrid.style.display = 'grid';
        resetBtn.style.display = 'none';
        endBtn.style.display = 'inline-flex';
        renderAvailableTeams();
        startTimer();
      } else {
        statusEl.className = 'draft-status inactive';
        const picksCount = state.picks?.length || 0;
        statusEl.innerHTML = picksCount > 0 
          ? `<div style="color:var(--green);font-size:16px;font-weight:600">Draft Complete!</div><div style="margin-top:8px">${picksCount} picks made</div>`
          : `<div>Click "Start Draft" or "Test Draft" to begin</div><div style="font-size:13px;color:rgba(255,255,255,0.5);margin-top:8px">Test mode lets you practice without saving picks</div>`;
        teamsGrid.style.display = 'none';
        resetBtn.style.display = picksCount > 0 ? 'inline-flex' : 'none';
        endBtn.style.display = 'none';
        stopTimer();
      }
      renderDraftOrder();
    }
    
    function renderAvailableTeams() {
      const draftedTeams = new Set(appData.draftState.picks?.map(p => p.team) || []);
      appData.players.forEach(p => p.teams.forEach(t => draftedTeams.add(t)));
      
      const teams = Object.entries(teamsData).sort((a, b) => a[1].seed - b[1].seed);
      document.getElementById('draftTeamsGrid').innerHTML = teams.map(([name, info]) => {
        const drafted = draftedTeams.has(name);
        const seedClass = info.seed <= 4 ? 'seed-1-4' : info.seed <= 8 ? 'seed-5-8' : info.seed <= 12 ? 'seed-9-12' : 'seed-13-16';
        return `<button class="draft-team-btn ${drafted ? 'drafted' : ''}" onclick="${drafted ? '' : `makePick('${name}')`}" ${drafted ? 'disabled' : ''}>
          <span class="seed-badge ${seedClass}">${info.seed}</span>
          <span>${name}</span>
        </button>`;
      }).join('');
    }
    
    async function startDraft(testMode) {
      const order = [0, 1, 2, 3]; // Default order
      await fetch('/api/draft/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ order, timerSeconds: 120, testMode })
      });
      await loadData();
      showToast(testMode ? '🧪 Test draft started!' : '🚀 Draft started!');
    }
    
    async function makePick(teamName) {
      const playerIndex = getCurrentPickerIndex();
      await fetch('/api/draft/pick', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ teamName, playerIndex })
      });
      await loadData();
      showToast(`${appData.players[playerIndex].name} drafted ${teamName}!`);
    }
    
    async function endDraft() {
      await fetch('/api/draft/end', { method: 'POST' });
      await loadData();
      showToast('Draft ended!');
    }
    
    async function resetDraft() {
      if (!confirm('Reset the draft? This will clear all picks.')) return;
      const clearTeams = confirm('Also clear team assignments from players?');
      await fetch('/api/draft/reset', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ clearTeams })
      });
      await loadData();
      showToast('Draft reset!');
    }
    
    function startTimer() {
      stopTimer();
      draftTimeLeft = appData.draftState.timerSeconds || 120;
      updateTimerDisplay();
      draftTimer = setInterval(() => {
        draftTimeLeft--;
        updateTimerDisplay();
        if (draftTimeLeft <= 0) {
          stopTimer();
          // Auto-pick best available
          autoPick();
        }
      }, 1000);
    }
    
    function stopTimer() {
      if (draftTimer) {
        clearInterval(draftTimer);
        draftTimer = null;
      }
    }
    
    function updateTimerDisplay() {
      const el = document.getElementById('draftTimerDisplay');
      if (el) {
        const mins = Math.floor(draftTimeLeft / 60);
        const secs = draftTimeLeft % 60;
        el.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;
        el.style.color = draftTimeLeft <= 30 ? '#ef4444' : '#f87171';
      }
    }
    
    async function autoPick() {
      const draftedTeams = new Set(appData.draftState.picks?.map(p => p.team) || []);
      appData.players.forEach(p => p.teams.forEach(t => draftedTeams.add(t)));
      const available = Object.entries(teamsData)
        .filter(([name]) => !draftedTeams.has(name))
        .sort((a, b) => a[1].seed - b[1].seed);
      if (available.length > 0) {
        await makePick(available[0][0]);
      }
    }
    
    function renderDraft() {
      document.getElementById('draftBoard').innerHTML = appData.players.map(p => {
        const teams = p.teams.map(t => {
          const info = teamsData[t]; if (!info) return '';
          const sc = info.seed <= 4 ? 'seed-1-4' : info.seed <= 8 ? 'seed-5-8' : info.seed <= 12 ? 'seed-9-12' : 'seed-13-16';
          return `<div class="draft-team" onclick="showTeamPopup('${t}')"><span class="seed-badge ${sc}">${info.seed}</span><span>${t}</span></div>`;
        }).join('');
        return `<div class="draft-player">
          <div class="draft-player-header">
            <div class="draft-player-avatar" style="background:linear-gradient(135deg,${p.colorPrimary},${p.colorSecondary})">${p.letter}</div>
            <div><div class="draft-player-name">${p.name}</div><div class="draft-player-count">${p.teams.length} teams</div></div>
          </div>
          <div class="draft-player-teams">${teams || '<div style="color:rgba(255,255,255,0.4);font-size:12px;padding:8px">No teams yet</div>'}</div>
        </div>`;
      }).join('');
    }
    
    function showTeamPopup(teamName) {
      const team = teamsData[teamName]; if (!team) return;
      let owner = null;
      appData.players.forEach(p => { if (p.teams.includes(teamName)) owner = p; });
      const champOdds = oddsData.championship[teamName];
      const ffOdds = oddsData.finalFour[teamName];
      
      document.getElementById('teamPopup').innerHTML = `
        <div class="popup-header" style="background:linear-gradient(135deg,${team.colors[0]},${team.colors[0]}cc)">
          <button class="popup-close" onclick="closePopup()">✕</button>
          <div class="popup-team-name">${teamName}</div>
          <div class="popup-team-info">#${team.seed} Seed · ${team.region} Region · ${team.record}</div>
        </div>
        ${champOdds || ffOdds ? `<div class="popup-section">
          <div class="popup-section-title">Championship Odds</div>
          <div class="odds-grid">
            ${champOdds ? `<div class="odds-item"><div class="odds-label">Championship</div><div class="odds-value">${champOdds}</div></div>` : ''}
            ${ffOdds ? `<div class="odds-item"><div class="odds-label">Final Four</div><div class="odds-value ${ffOdds.startsWith('-')?'negative':''}">${ffOdds}</div></div>` : ''}
            <div class="odds-item"><div class="odds-label">NET Rank</div><div class="odds-value">#${team.net}</div></div>
          </div>
        </div>` : ''}
        <div class="popup-section">
          <div class="popup-section-title">Quadrant Record</div>
          <div class="quadrant-grid">
            <div class="quadrant-item"><div class="quadrant-label">Q1</div><div class="quadrant-value">${team.q1}</div></div>
            <div class="quadrant-item"><div class="quadrant-label">Q2</div><div class="quadrant-value">${team.q2}</div></div>
            <div class="quadrant-item"><div class="quadrant-label">Q3</div><div class="quadrant-value">${team.q3}</div></div>
            <div class="quadrant-item"><div class="quadrant-label">Q4</div><div class="quadrant-value">${team.q4}</div></div>
          </div>
        </div>
        ${owner ? `<div class="popup-owner">
          <div class="popup-owner-avatar" style="background:linear-gradient(135deg,${owner.colorPrimary},${owner.colorSecondary})">${owner.letter}</div>
          <div><div class="popup-owner-label">Drafted by</div><div class="popup-owner-name">${owner.name}</div></div>
        </div>` : ''}`;
      document.getElementById('popupOverlay').classList.add('active');
    }
    
    function closePopup() { document.getElementById('popupOverlay').classList.remove('active'); }
    document.getElementById('popupOverlay').addEventListener('click', e => { if (e.target.id === 'popupOverlay') closePopup(); });
    
    function showToast(msg) {
      const toast = document.getElementById('toast');
      toast.textContent = msg;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 2500);
    }
    
    setInterval(loadLiveGames, 30000);
    setInterval(() => { if (appData?.draftState?.active) loadData(); }, 3000); // Poll draft state
    loadData();
  </script>
</body>
</html>

